{
  "name": "@rvct/asyncapi-codegen",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format": "eslint --fix . && prettier --write .",
    "format.check": "eslint . && prettier --check ."
  },
  "description": "AsyncAPI to TypeScript and Zod code generator",
  "main": "./src/index.mjs",
  "module": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./cli": "./src/cli.mjs"
  },
  "bin": {
    "asyncapi-codegen": "./src/cli.mjs"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "asyncapi",
    "codegen",
    "typescript",
    "zod"
  ],
  "dependencies": {
    "@asyncapi/parser": "^3.6.0",
    "json-schema-to-typescript": "^15.0.4",
    "json-schema-to-zod": "^2.7.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1"
  }
}
