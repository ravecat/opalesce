{
  "name": "@rvct/asyncapi",
  "version": "0.1.0",
  "description": "Config-driven AsyncAPI to JSON Schema, TypeScript, and Zod generator",
  "keywords": [
    "asyncapi",
    "codegen",
    "typescript",
    "zod"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravecat/asyncapi.git"
  },
  "bin": {
    "asyncapi-codegen": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./config": "./dist/config.js",
    "./plugins": "./dist/plugins/index.js",
    "./plugins/asyncapi": "./dist/plugins/asyncapi.js",
    "./plugins/typescript": "./dist/plugins/typescript.js",
    "./plugins/zod": "./dist/plugins/zod.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc-alias -p tsconfig.json -f",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test",
    "lint": "eslint .",
    "format": "eslint . --fix && oxfmt .",
    "format:check": "oxfmt --check .",
    "format.check": "pnpm run format:check",
    "release": "semantic-release",
    "test": "pnpm run test:unit && pnpm run test:smoke",
    "test:unit": "vitest run --project unit",
    "test:smoke": "vitest run --project smoke",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@asyncapi/parser": "^3.6.0",
    "json-schema-to-typescript": "^15.0.4",
    "json-schema-to-zod": "^2.7.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.1",
    "oxfmt": "^0.54.0",
    "semantic-release": "25.0.3",
    "semantic-release-run-when": "1.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.34.0"
}
